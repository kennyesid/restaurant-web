{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Levantar Next.js (Servidor)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Conectar al Navegador (Cliente)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "DEPURAR FULL (Servidor + Cliente)",
      "configurations": ["Levantar Next.js (Servidor)", "Conectar al Navegador (Cliente)"]
    }
  ]
}




